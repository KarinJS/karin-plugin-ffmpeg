{
  "name": "@karinjs/plugin-ffmpeg",
  "version": "0.1.2",
  "author": "ikenxuan",
  "type": "module",
  "description": "Provide Karin with an out of the box plugin for ffmpeg binary files",
  "homepage": "https://github.com/KarinJS/karin-plugin-ffmpeg",
  "bugs": {
    "url": "https://github.com/KarinJS/karin-plugin-ffmpeg/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KarinJS/karin-plugin-ffmpeg.git"
  },
  "keywords": [
    "karin",
    "ffmpeg",
    "video",
    "audio",
    "media",
    "converter"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "cross-env EBV_FILE=\"development.env\" tsx src/app.ts",
    "test": "vitest run",
    "pub": "npm publish --access public"
  },
  "main": "dist/index.mjs",
  "devDependencies": {
    "@types/node": "25.5.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "neostandard": "^0.13.0",
    "node-karin": "1.14.4",
    "tsdown": "^0.21.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "karin": {
    "files": [
      "config"
    ],
    "main": "src/index.ts",
    "web": "dist/web.config.mjs",
    "ts-web": "src/web.config.ts"
  },
  "files": [
    "/dist/**/*.mjs",
    "/dist/**/*.d.mts",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}